---
import { Laptop, Cpu, MemoryStick, Gpu, HardDrive, Terminal } from '@lucide/astro';
import { Webstorm, Goland, Git, Github, Firefoxbrowser, Bun, Postgresql, Sqlite, Insomnia, Discord, Youtubemusic, Bitwarden, Vmware, Zsh } from 'simple-icons-astro';
import HeliumBrowser from './HeliumBrowser.astro';

const specs = [
  {
    name: 'OS',
    Icon: Laptop,
    value: 'Arch Linux with Hyprland',
  },
  {
    name: 'CPU',
    Icon: Cpu,
    value: 'AMD Ryzen 7 2700 Eight-Core Processor @ 3.20 GHz',
  },
  {
    name: 'RAM',
    Icon: MemoryStick,
    value: '32 GB',
  },
  {
    name: 'GPU',
    Icon: Gpu,
    value: 'NVIDIA GeForce RTX 3060 Ti',
  },
  {
    name: 'Storage',
    Icon: HardDrive,
    value: 'PNY CS900 960GB<br/>Samsung SSD 870 QVO 1TB<br/>Predator SSD GM7000 1TB',
  },
];

const software = [
  { name: 'WebStorm', category: 'Editor', Icon: Webstorm },
  { name: 'GoLand', category: 'Editor', Icon: Goland },
  { name: 'kitty', category: 'Terminal', Icon: Terminal },
  { name: 'Zsh', category: 'Shell', Icon: Zsh },
  { name: 'Git', category: 'VCS', Icon: Git },
  { name: 'GitHub', category: 'VCS', Icon: Github },
  { name: 'Firefox Nightly', category: 'Browser', Icon: Firefoxbrowser },
  { name: 'Helium', category: 'Browser', Icon: HeliumBrowser },
  { name: 'Bun', category: 'JS Runtime', Icon: Bun },
  { name: 'PostgreSQL', category: 'Database', Icon: Postgresql },
  { name: 'SQLite', category: 'Database', Icon: Sqlite },
  { name: 'Insomnia', category: 'API Testing', Icon: Insomnia },
  { name: 'Discord', category: 'Communication', Icon: Discord },
  { name: 'YouTube Music', category: 'Music', Icon: Youtubemusic },
  { name: 'Bitwarden', category: 'Passwords', Icon: Bitwarden },
  { name: 'VMware', category: 'Virtualization', Icon: Vmware },
];
---
<div class="container px-4 py-8 pt-28 max-w-7xl mx-auto grid gap-8" id="setup">
  <div class="shadow-md rounded-lg p-6 relative">
    <img
      src="https://raw.githubusercontent.com/CuteTenshii/dotfiles/refs/heads/master/desktop.png" draggable="false"
      alt="Desktop Setup" width={800} height={450}
      class="absolute inset-0 rounded-lg mb-4 size-full object-cover z-0 opacity-50 object-top blur-[1px]"
    />

    <div class="z-10 relative text-center">
      <h3 class="text-2xl font-semibold mb-4">PC Specs</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        {specs.map(({ name, Icon, value }) => (
          <div class="flex py-4 px-2 flex-col justify-center items-center text-center">
            <Icon size={32} />
            <span class="pt-4 font-bold pb-1">{name}</span>
            <span><Fragment set:html={value} /></span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="bg-gray-800 shadow-md rounded-lg p-6">
    <h3 class="text-2xl font-semibold mb-6">Software Stack</h3>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-3">
      {software.map(({ name, category, Icon }) => (
        <div class="flex flex-col items-center gap-2 p-3 rounded-lg bg-gray-700/50 hover:bg-gray-700 transition-colors text-center">
          <Icon size={32} />
          <span class="text-sm font-medium leading-tight">{name}</span>
          <span class="text-xs text-gray-400">{category}</span>
        </div>
      ))}
    </div>
  </div>
</div>
