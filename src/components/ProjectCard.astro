---
import { Star, Clock } from "@lucide/astro";

interface Props {
  name: string;
  description: string;
  link: string;
  image: string | null;
  github: string | null;
  category: string;
  categoryLabel: string;
  categoryClass: string;
  tech: { name: string; Icon: any }[];
}

const { name, description, link, image, github, category, categoryLabel, categoryClass, tech } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="noopener"
  data-category={category}
  class="group border border-gray-700 rounded-xl p-5 hover:border-gray-500 bg-gray-800/30 hover:bg-gray-800/60 transition-all duration-200 backdrop-blur-lg flex flex-col gap-3"
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap mb-2">
        <h3 class="text-base font-semibold group-hover:text-white leading-tight">{name}</h3>
        <span class={`text-xs px-2 py-0.5 rounded-full shrink-0 ${categoryClass}`}>
          {categoryLabel}
        </span>
      </div>
      <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
    </div>
    {image && (
      <img
        src={image}
        alt={`${name} logo`}
        draggable="false"
        width={56}
        height={56}
        class="w-14 h-14 rounded-lg object-cover shrink-0"
      />
    )}
  </div>

  <div class="flex flex-wrap gap-1.5 mt-auto">
    {tech.map((t) => (
      <div class="flex items-center gap-1 text-xs text-gray-400 bg-gray-700/60 px-2 py-1 rounded-md">
        <t.Icon size={11} />
        <span>{t.name}</span>
      </div>
    ))}
  </div>

  {github && (
    <div
      class="hidden items-center gap-4 text-xs text-gray-500 pt-2 border-t border-gray-700/50"
      data-github={github}
    >
      <span class="flex items-center gap-1">
        <Star size={12} />
        <span data-github-stars>–</span>
      </span>
      <span class="flex items-center gap-1">
        <Clock size={12} />
        <span>Updated </span><span data-github-updated>–</span>
      </span>
    </div>
  )}
</a>
