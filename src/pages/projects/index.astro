---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import {
  Go,
  Typescript,
  Nextdotjs,
  Tailwindcss,
  Postgresql,
  Electron,
  Cloudflare,
  Archlinux,
  Zsh,
  Astro as AstroIcon,
} from "simple-icons-astro";

type Tech = { name: string; Icon: any };

const T = {
  Go:        { name: "Go",           Icon: Go },
  TS:        { name: "TypeScript",   Icon: Typescript },
  NextJS:    { name: "Next.js",      Icon: Nextdotjs },
  Tailwind:  { name: "Tailwind CSS", Icon: Tailwindcss },
  PG:        { name: "PostgreSQL",   Icon: Postgresql },
  Astro:     { name: "Astro",        Icon: AstroIcon },
  Electron:  { name: "Electron",     Icon: Electron },
  CF:        { name: "Cloudflare",   Icon: Cloudflare },
  ArchLinux: { name: "Arch Linux",   Icon: Archlinux },
  Zsh:       { name: "Zsh",          Icon: Zsh },
} satisfies Record<string, Tech>;

const categories = [
  { id: "web",       label: "Web" },
  { id: "desktop",   label: "Desktop" },
  { id: "tool",      label: "Tool" },
  { id: "reversing", label: "Reverse Engineering" },
  { id: "config",    label: "Config" },
] as const;

type CategoryId = (typeof categories)[number]["id"];

const categoryStyle: Record<CategoryId, string> = {
  web:       "bg-blue-900/50 text-blue-300",
  desktop:   "bg-purple-900/50 text-purple-300",
  tool:      "bg-green-900/50 text-green-300",
  reversing: "bg-orange-900/50 text-orange-300",
  config:    "bg-gray-700/80 text-gray-300",
};

const projects: Array<{
  name: string;
  description: string;
  link: string;
  image: string | null;
  github: string | null;
  category: CategoryId;
  tech: Tech[];
}> = [
  {
    name: "Miwa.lol",
    description: "A modern and customizable biolinks website, already used by more than 1,900 users!",
    link: "https://miwa.lol",
    image: "https://miwa.lol/images/miwa-256.png",
    github: null,
    category: "web",
    tech: [T.NextJS, T.Tailwind, T.Go, T.PG],
  },
  {
    name: "Tenshii.moe",
    description: "My personal website, you are currently on it!",
    link: "https://tenshii.moe",
    image: "/img/pfp.webp",
    github: "CuteTenshii.github.io",
    category: "web",
    tech: [T.Astro, T.TS, T.Tailwind],
  },
  {
    name: "Deezer Discord RPC",
    description: "A Discord RPC for Deezer.",
    link: "https://github.com/CuteTenshii/deezer-discord-rpc",
    image: "https://raw.githubusercontent.com/CuteTenshii/deezer-discord-rpc/refs/heads/master/.github/screenshots/rpc.png",
    github: "deezer-discord-rpc",
    category: "desktop",
    tech: [T.Electron, T.TS],
  },
  {
    name: "guns.lol solver",
    description: "Reverse engineering of the PoW used to record views on guns.lol profile pages. The README includes a detailed explanation of how the PoW works.",
    link: "https://github.com/CuteTenshii/guns-solver",
    image: null,
    github: "guns-solver",
    category: "reversing",
    tech: [T.Go],
  },
  {
    name: "Crunchyroll Downloader",
    description: "A Go program to download episodes from Crunchyroll. Merges video and audio segments (and optionally subtitles) into a MKV container.",
    link: "https://github.com/CuteTenshii/crunchyroll-downloader",
    image: null,
    github: "crunchyroll-downloader",
    category: "tool",
    tech: [T.Go],
  },
  {
    name: "dotfiles",
    description: "My dotfiles for Arch Linux with Hyprland, zsh, kitty... Also includes scripts I made for my VPS.",
    link: "https://github.com/CuteTenshii/dotfiles",
    image: "https://raw.githubusercontent.com/CuteTenshii/dotfiles/master/desktop.png",
    github: "dotfiles",
    category: "config",
    tech: [T.ArchLinux, T.Zsh],
  },
  {
    name: "Paradise Bay server",
    description: 'Reverse-engineering of the custom protocol of the 2015 "Paradise Bay" game.',
    link: "https://github.com/CuteTenshii/paradise-bay-server",
    image: null,
    github: "paradise-bay-server",
    category: "reversing",
    tech: [T.Go],
  },
  {
    name: "favicon",
    description: "A Cloudflare Worker that serves a website's favicon from a given URL.",
    link: "https://github.com/CuteTenshii/favicon",
    image: null,
    github: "favicon",
    category: "tool",
    tech: [T.TS, T.CF],
  },
];

const githubToken = import.meta.env.PUBLIC_GITHUB_TOKEN ?? "";
---

<BaseLayout
  title="Projects - Tenshii.moe"
  description="A few projects I've worked on. You can see more on my GitHub: https://github.com/CuteTenshii"
>
  <div class="container mx-auto px-4 py-8 pt-16" id="projects">
    <h2 class="text-3xl font-bold text-center mb-3">Projects</h2>
    <p class="text-center mb-8 text-gray-400">
      A few projects I've worked on. You can see more on my{" "}
      <a href="https://github.com/CuteTenshii" target="_blank" rel="noopener">GitHub</a>.
    </p>

    <div class="flex flex-wrap gap-2 mb-8 justify-center" id="category-filters">
      <button
        data-filter="all"
        class="filter-btn active px-4 py-1.5 rounded-full text-sm font-medium transition-colors cursor-pointer"
      >All</button>
      {categories.map((cat) => (
        <button
          data-filter={cat.id}
          class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors cursor-pointer ${categoryStyle[cat.id]}`}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="projects-grid">
      {projects.map((project) => (
        <ProjectCard
          {...project}
          categoryLabel={categories.find((c) => c.id === project.category)!.label}
          categoryClass={categoryStyle[project.category]}
        />
      ))}
    </div>
  </div>

  <style>
    .filter-btn { background-color: rgb(55 65 81 / 0.5); color: rgb(209 213 219); }
    .filter-btn:hover { background-color: rgb(55 65 81); }
    .filter-btn.active { background-color: white; color: rgb(17 24 39); }
  </style>

  <script define:vars={{ githubToken }}>
    function initFilters() {
      const buttons = document.querySelectorAll(".filter-btn");
      const cards = document.querySelectorAll("[data-category]");
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const filter = btn.dataset.filter;
          buttons.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          cards.forEach((card) => {
            card.classList.toggle("hidden", filter !== "all" && card.dataset.category !== filter);
          });
        });
      });
    }

    function formatDate(iso) {
      return new Date(iso).toLocaleDateString("en-US", { month: "short", year: "numeric" });
    }

    async function loadGithubStats() {
      if (!githubToken) return;

      const containers = Array.from(document.querySelectorAll("[data-github]"));
      if (!containers.length) return;

      const repos = containers.map((el) => el.dataset.github);
      const query = `{ ${repos.map((repo, i) => `
        r${i}: repository(owner: "CuteTenshii", name: "${repo}") {
          name stargazerCount pushedAt
        }`).join("")} }`;

      try {
        const res = await fetch("https://api.github.com/graphql", {
          method: "POST",
          headers: { Authorization: `Bearer ${githubToken}`, "Content-Type": "application/json" },
          body: JSON.stringify({ query }),
        });
        const { data } = await res.json();
        if (!data) return;

        const byName = Object.fromEntries(
          Object.values(data).filter(Boolean).map((v) => [v.name, v])
        );

        containers.forEach((el) => {
          const val = byName[el.dataset.github];
          if (!val) return;
          el.querySelector("[data-github-stars]").textContent = val.stargazerCount.toLocaleString();
          el.querySelector("[data-github-updated]").textContent = formatDate(val.pushedAt);
          el.classList.remove("hidden");
          el.classList.add("flex");
        });
      } catch {}
    }

    document.addEventListener("astro:page-load", () => { initFilters(); loadGithubStats(); });
    initFilters();
    loadGithubStats();
  </script>
</BaseLayout>
